class Solution {
    public int maxDepth(String str) {
       int ans=0;
       Stack<Character> s=new Stack<>();
       for(int i=0;i<str.length();i++){
        char ch=str.charAt(i);
        if(ch== '('){
            s.push(ch);
            ans=Math.max(ans,s.size());
        }else if(ch== ')'){
            s.pop();
        }
       }
       return ans;
    }
}
