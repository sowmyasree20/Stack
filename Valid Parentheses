class Solution {
    public boolean isValid(String s) {
        Stack<Character> k=new Stack();
        for(int i=0;i<s.length();i++){
            char ch=s.charAt(i);
            if(ch=='(' || ch=='{' || ch=='['){
                k.push(ch);
            }else{
                if(k.isEmpty())
                 return false;
                char top=k.pop();
                if(ch==')' && top!='(')
                 return false;
                if(ch==']' && top!='[')
                 return false;
                if(ch=='}' && top!='{')
                 return false;
            }
        }
           return k.isEmpty(); 
    }
}
